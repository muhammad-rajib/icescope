{
  "name": "icescope",
  "version": "0.1.0",
  "private": false,
  "description": "Desktop explorer for Apache Iceberg warehouses",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "lint": "tsc --noEmit",
    "build": "tsc && vite build",
    "tauri:build": "tauri build",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "docs:dev": "npx --yes vitepress@1.6.4 dev docs",
    "docs:build": "npx --yes vitepress@1.6.4 build docs",
    "docs:preview": "npx --yes vitepress@1.6.4 preview docs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@uiw/react-codemirror": "^4.23.0",
    "@tanstack/react-virtual": "^3.10.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
